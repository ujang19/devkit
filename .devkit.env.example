# =============================================================================
# devkit secrets — COPY this file, do NOT commit the real one
#
#   cp ~/linux-devkit/.devkit.env.example ~/.devkit.env
#   nano ~/.devkit.env          # isi token asli
#   source ~/linux-devkit/scripts/export-env.sh
#   bash ~/linux-devkit/run.sh
#
# Atau satu langkah:
#   bash ~/linux-devkit/scripts/install-full.sh
# =============================================================================

# ── GitHub (wajib untuk private: wabase, wazapin) ───────────────────────────
# Buat di: GitHub → Settings → Developer settings → Personal access tokens
# Fine-grained: Contents = Read (repo wabase/*, wazapin/*)
# Classic: scope "repo"
GH_TOKEN=github_pat_ISI_DISINI

# Alternatif nama (gh juga baca ini):
# GITHUB_TOKEN=github_pat_ISI_DISINI

# ── Infisical Universal Auth (Machine Identity) ─────────────────────────────
# Dashboard → Organization → Access Control → Machine Identities
# → Universal Auth → Client ID + Client Secret
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET=ISI_CLIENT_SECRET_DISINI

# Domain API Infisical
# US (default):
INFISICAL_DOMAIN=https://app.infisical.com/api
# EU:
# INFISICAL_DOMAIN=https://eu.infisical.com/api

# Environment vault (dev / staging / prod)
INFISICAL_ENV=dev

# Opsional: project id kalau run di luar folder yang punya .infisical.json
# INFISICAL_PROJECT_ID=

# ── Cloudflare (opsional — biasanya diisi DI DALAM Infisical vault) ─────────
# Kalau mau export manual di shell (tanpa Infisical dulu):
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# ── run.sh options ──────────────────────────────────────────────────────────
DEVKIT_PROFILE=default
DEVKIT_WITH_DOCKER=0
DEVKIT_SKIP_SKILLS=0
DEVKIT_SKIP_INSTALL_DEPS=0
DEVKIT_KIT_REPO=https://github.com/ujang19/devkit.git
